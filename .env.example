# Copy this file to .env and fill in the real values.
# Never commit .env itself.

# ── MongoDB Atlas ──────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/bhashaflow

# ── Backend ────────────────────────────────────────────
JWT_SECRET=<64-char hex string — same value everyone uses>
PORT=5000

# ── Gmail SMTP (for follow-up emails) ─────────────────
# How to get App Password:
# Google Account → Security → 2FA → App Passwords → Mail
GMAIL_USER=<gmail address for sending follow-up emails>
GMAIL_PASS=<gmail app password — NOT your login password>

# ── Tech Lead Alerts ──────────────────────────────────
TECH_LEAD_EMAIL=<saumya's email for Jenkins failure alerts>

# ── AI Engine ──────────────────────────────────────────
SARVAM_API_KEY=<from Sarvam AI — used by ai-engine>
GEMINI_API_KEY=<Google AI Studio key — used by ai-engine>