# ── MongoDB Atlas ──────────────────────────────────────
MONGO_URI=<YOUR_REAL_MONGO_URI>

# ── Backend ────────────────────────────────────────────
JWT_SECRET=<YOUR_REAL_JWT_SECRET>
PORT=5000

# ── Gmail SMTP (for follow-up emails) ─────────────────
GMAIL_USER=<YOUR_GMAIL_ADDRESS>
GMAIL_PASS=<YOUR_GMAIL_APP_PASSWORD>

# ── Tech Lead Alerts ──────────────────────────────────
TECH_LEAD_EMAIL=saumyasrivastava611@gmail.com

# ── AI Engine ──────────────────────────────────────────
SARVAM_API_KEY=<YOUR_REAL_SARVAM_KEY>
GEMINI_API_KEY=<YOUR_REAL_GEMINI_KEY>
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_FALLBACK_MODELS=gemini-3-flash-preview,gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash
GEMINI_ENABLE_OCR_SCRIPT_DETECTION=false
GEMINI_ENABLE_OCR_CLEANUP=false
ENABLE_EASYOCR=false
REQUEST_TIMEOUT=20
MAX_OCR_FILE_BYTES=4194304
MAX_AUDIO_FILE_BYTES=4194304
MAX_TEXT_CHARS=4000
MAX_OCR_TEXT_CHARS=2500
MAX_PDF_PAGES=2
PDF_RENDER_SCALE=1.35

# ── Google OAuth ───────────────────────────────────────
GOOGLE_CLIENT_ID=<YOUR_REAL_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YOUR_REAL_GOOGLE_CLIENT_SECRET>

# ── Frontend Variables (Vite requires the VITE_ prefix) ─
VITE_GOOGLE_CLIENT_ID=<YOUR_REAL_GOOGLE_CLIENT_ID_AGAIN>
VITE_BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
