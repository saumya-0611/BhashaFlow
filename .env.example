# Copy this file to .env and fill in the real values.
# Never commit .env itself.

# ── MongoDB Atlas ──────────────────────────────────────
MONGO_URI=mongodb+srv://<same atlas string>

# ── Backend ────────────────────────────────────────────
JWT_SECRET=<same hex secret everyone uses>
PORT=5000

# ── AI Engine ──────────────────────────────────────────
SARVAM_API_KEY=<same sarvam key>